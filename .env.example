LLM_PROVIDER=ollama
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=resume-comparison-narrator:latest
OLLAMA_LLM_FALLBACK_MODELS=qwen3:8b,qwen3.5:latest,llama3.2:latest
OLLAMA_USE_MODELFILE_SYSTEM_PROMPTS=true
OLLAMA_LLM_TIMEOUT_SECONDS=45
OLLAMA_LLM_NUM_PREDICT=300
ENABLE_JD_CLEANER_LLM=true
JD_CLEANER_LLM_MODE=always
JD_CLEANER_MIN_RULE_REQUIREMENTS=4
OLLAMA_JD_CLEANER_MODEL=resume-jd-cleaner:latest
OLLAMA_JD_CLEANER_TIMEOUT_SECONDS=12
OLLAMA_JD_CLEANER_NUM_PREDICT=450
ENABLE_RESUME_CONTEXT_LLM=true
RESUME_CONTEXT_LLM_MODE=auto
RESUME_CONTEXT_MIN_ACTION_ITEMS=3
RESUME_CONTEXT_MIN_SKILLS=5
OLLAMA_RESUME_CONTEXT_MODEL=resume-context-classifier:latest
OLLAMA_RESUME_CONTEXT_TIMEOUT_SECONDS=25
OLLAMA_RESUME_CONTEXT_NUM_PREDICT=450
ENABLE_COMPARISON_NARRATIVE_LLM=false
ENABLE_INFERENCE_MATCH_LLM=true
INFERENCE_MATCH_BATCH_MODE=false
INFERENCE_MATCH_BATCH_SIZE=8
INFERENCE_MATCH_MIN_SIMILARITY=0.32
OLLAMA_INFERENCE_MATCH_MODEL=resume-inference-matcher:latest
OLLAMA_INFERENCE_MATCH_TIMEOUT_SECONDS=10
OLLAMA_INFERENCE_MATCH_NUM_PREDICT=280
OLLAMA_INFERENCE_MATCH_BATCH_TIMEOUT_SECONDS=18
OLLAMA_INFERENCE_MATCH_BATCH_NUM_PREDICT=900
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large:latest
OLLAMA_EMBEDDING_FALLBACK_MODELS=nomic-embed-text,snowflake-arctic-embed:latest
OLLAMA_EMBEDDING_BATCH_SIZE=32
RAG_RETRIEVAL_MAX_WORKERS=8
INFERENCE_MATCH_MAX_WORKERS=3
ENABLE_MOCK_FALLBACK=false
VECTOR_STORE_PROVIDER=qdrant
ENABLE_VECTOR_STORE_FALLBACK=true
QDRANT_URL=http://qdrant:6333
DATABASE_URL=sqlite:///./data/app.db
MAX_UPLOAD_MB=8
ENABLE_MOCK_MODE=false
NEXT_PUBLIC_API_BASE=http://localhost:8000
